{
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "preact"
  },
  "exclude": [
    ".agents/"
  ],
  "tasks": {
    "dev": "deno run --watch --allow-net --allow-read --allow-write main.ts"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1",
    "preact": "npm:preact@^10.27.2",
    "preact-render-to-string": "npm:preact-render-to-string@^6.6.2"
  },
  "fmt": {
    "useTabs": false,
    "indentWidth": 2,
    "lineWidth": 80,
    "semiColons": true,
    "singleQuote": false
  }
}
